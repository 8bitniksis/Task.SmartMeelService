<Window x:Class="Sms.WpfEnvManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Environment Variable Manager"
        Width="850"
        Height="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent">

    <Border
        Background="White"
        BorderBrush="#C8C8C8"
        BorderThickness="1"
        CornerRadius="18">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Margin="15,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    FontSize="14"
                    Text="Тестовое WPF-приложение для SmartMealService"/>

                <!-- Minimize -->
                <Button Grid.Column="1"
                        Style="{StaticResource WindowButtonStyle}"
                        Click="MinimizeButton_Click">

                    <TextBlock Text="─"
                               FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                </Button>

                <!-- Close -->
                <Button Grid.Column="2"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="CloseButton_Click">

                    <TextBlock Text="✕"
                               FontSize="12"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                </Button>

            </Grid>

            <!-- CONTENT -->
            <Grid Grid.Row="1"
                  Margin="15">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Label Content="Переменные среды:"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

                <DataGrid Grid.Row="1"
                          x:Name="EnvVariablesGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1"
                          RowEditEnding="EnvVariablesGrid_RowEditEnding">

                    <DataGrid.Columns>

                        <DataGridTextColumn
                            Header="Поле"
                            Binding="{Binding Name}"
                            Width="2*"/>

                        <DataGridTextColumn
                            Header="Значение"
                            Binding="{Binding Value}"
                            Width="3*"/>

                        <DataGridTextColumn
                            Header="Комментарий"
                            Binding="{Binding Comment}"
                            Width="2*"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

            <!-- FOOTER -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="15">

                <Button x:Name="SaveAllButton"
                        Width="170"
                        Height="34"
                        Content="Сохранить изменения"
                        Click="SaveAllButton_Click"/>

            </StackPanel>

        </Grid>

    </Border>

</Window>