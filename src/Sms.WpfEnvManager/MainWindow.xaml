<Window x:Class="Sms.WpfEnvManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Environment Variable Manager" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Переменные среды:" FontWeight="Bold" />

        <DataGrid Grid.Row="1"
                  x:Name="EnvVariablesGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowEditEnding="EnvVariablesGrid_RowEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Поле" Binding="{Binding Name}" Width="2*" />
                <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="3*" />
                <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2"
                x:Name="SaveAllButton"
                Content="Сохранить все изменения"
                Width="150" Height="30"
                HorizontalAlignment="Left"
                Click="SaveAllButton_Click"/>
    </Grid>
</Window>